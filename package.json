{
  "name": "payer-portal",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present run dev",
    "dev:portal": "pnpm --filter portal-web dev",
    "dev:admin": "pnpm --filter admin-console dev",
    "dev:api": "pnpm --filter api dev",
    "dev:worker": "pnpm --filter @payer-portal/server worker:jobs",
    "services:start": "bash ./scripts/start-services.sh",
    "services:start:with-worker": "ENABLE_JOB_WORKER=true bash ./scripts/start-services.sh",
    "services:stop": "bash ./scripts/stop-services.sh",
    "services:status": "bash ./scripts/status-services.sh",
    "services:restart": "bash ./scripts/restart-services.sh",
    "create-plugin": "node scripts/create-plugin.mjs",
    "db:migrate": "pnpm --filter @payer-portal/database db:migrate",
    "db:seed": "pnpm --filter @payer-portal/database db:seed",
    "db:repair:admin-identities": "pnpm --filter @payer-portal/database db:repair:admin-identities",
    "db:seed:eb-demo": "pnpm --filter @payer-portal/database db:seed:eb-demo",
    "db:setup:eb-demo": "bash ./scripts/setup-eb-demo-db.sh",
    "services:start:eb-demo": "bash ./scripts/start-services-eb-demo.sh",
    "build": "pnpm -r --if-present run build",
    "lint": "eslint apps packages plugins --ext .ts,.tsx",
    "format": "prettier --write .",
    "audit:repo": "node ./scripts/audit-repo-hygiene.mjs",
    "test:smoke": "node ./scripts/testing/run-smoke-tests.mjs",
    "test:integration": "node ./scripts/testing/run-integration-tests.mjs",
    "validate:release": "node ./scripts/testing/validate-release.mjs",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.5.12",
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
