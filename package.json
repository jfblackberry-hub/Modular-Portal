{
  "name": "payer-portal",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.5",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present run dev",
    "dev:portal": "pnpm --filter portal-web dev",
    "dev:admin": "pnpm --filter admin-console dev",
    "dev:api": "pnpm --filter api dev",
    "services:start": "bash ./scripts/start-services.sh",
    "services:stop": "bash ./scripts/stop-services.sh",
    "services:status": "bash ./scripts/status-services.sh",
    "services:restart": "bash ./scripts/restart-services.sh",
    "create-plugin": "node scripts/create-plugin.mjs",
    "db:migrate": "pnpm --filter @payer-portal/database db:migrate",
    "db:seed": "pnpm --filter @payer-portal/database db:seed",
    "build": "pnpm -r --if-present run build",
    "lint": "eslint apps packages plugins --ext .ts,.tsx",
    "format": "prettier --write .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}
