      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (status) (increase(platform_workflow_execution_duration_ms_count[10m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
