      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "2 - 2 * clamp_max(((max(up{job=\"integrations/unix\",env=\"dev\",service=\"modular-portal\"}) < bool 1) + (max(up{job=\"prometheus.scrape.api\",env=\"dev\",service=\"modular-portal\"}) < bool 1) + ((100 * sum(rate(platform_api_errors_total{env=\"dev\",service=\"modular-portal\"}[5m])) / clamp_min(sum(rate(platform_api_requests_total{env=\"dev\",service=\"modular-portal\"}[5m])), 0.001)) > bool 5) + ((100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\",env=\"dev\",service=\"modular-portal\"}[5m])))) > bool 95) + ((100 * (1 - (sum(node_memory_MemAvailable_bytes{env=\"dev\",service=\"modular-portal\"}) / sum(node_memory_MemTotal_bytes{env=\"dev\",service=\"modular-portal\"})))) > bool 95) + ((100 * (1 - (sum(node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\",env=\"dev\",service=\"modular-portal\"}) / sum(node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\",env=\"dev\",service=\"modular-portal\"})))) > bool 95), 1) - (1 - clamp_max(((max(up{job=\"integrations/unix\",env=\"dev\",service=\"modular-portal\"}) < bool 1) + (max(up{job=\"prometheus.scrape.api\",env=\"dev\",service=\"modular-portal\"}) < bool 1) + ((100 * sum(rate(platform_api_errors_total{env=\"dev\",service=\"modular-portal\"}[5m])) / clamp_min(sum(rate(platform_api_requests_total{env=\"dev\",service=\"modular-portal\"}[5m])), 0.001)) > bool 5) + ((100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\",env=\"dev\",service=\"modular-portal\"}[5m])))) > bool 95) + ((100 * (1 - (sum(node_memory_MemAvailable_bytes{env=\"dev\",service=\"modular-portal\"}) / sum(node_memory_MemTotal_bytes{env=\"dev\",service=\"modular-portal\"})))) > bool 95) + ((100 * (1 - (sum(node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\",env=\"dev\",service=\"modular-portal\"}) / sum(node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\",env=\"dev\",service=\"modular-portal\"})))) > bool 95), 1)) * clamp_max((((100 * sum(rate(platform_api_errors_total{env=\"dev\",service=\"modular-portal\"}[5m])) / clamp_min(sum(rate(platform_api_requests_total{env=\"dev\",service=\"modular-portal\"}[5m])), 0.001)) > bool 1) + ((100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\",env=\"dev\",service=\"modular-portal\"}[5m])))) > bool 80) + ((100 * (1 - (sum(node_memory_MemAvailable_bytes{env=\"dev\",service=\"modular-portal\"}) / sum(node_memory_MemTotal_bytes{env=\"dev\",service=\"modular-portal\"})))) > bool 80) + ((100 * (1 - (sum(node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\",env=\"dev\",service=\"modular-portal\"}) / sum(node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay\",env=\"dev\",service=\"modular-portal\"})))) > bool 85), 1)",
          "refId": "A"
        }
      ],
      "title": "Platform Status"
    },
