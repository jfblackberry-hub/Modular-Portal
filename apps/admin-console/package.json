{
  "name": "admin-console",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "predev": "node ../../scripts/ensure-next-types.mjs admin-console --mode dev && pnpm --filter @payer-portal/config build",
    "dev": "APP_NAME=admin-console node ../../scripts/run-next-app.mjs admin-console dev",
    "prebuild": "node ../../scripts/ensure-next-types.mjs admin-console --mode build && pnpm --filter @payer-portal/config build",
    "build": "APP_NAME=admin-console NEXT_DIST_DIR=.next SKIP_RUNTIME_CONFIG_VALIDATION=1 next build",
    "start": "APP_NAME=admin-console node ../../scripts/run-next-app.mjs admin-console start",
    "prelint": "node ../../scripts/ensure-next-types.mjs admin-console --mode typecheck && pnpm --filter @payer-portal/config build",
    "lint": "eslint . --ext .ts,.tsx,.mjs",
    "pretest": "node ../../scripts/ensure-next-types.mjs admin-console --mode typecheck && pnpm --filter @payer-portal/config build",
    "pretypecheck": "node ../../scripts/ensure-next-types.mjs admin-console --mode typecheck && pnpm --filter @payer-portal/config build",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 tests/**/*.test.ts"
  },
  "dependencies": {
    "@payer-portal/config": "workspace:*",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "lucide-react": "^0.542.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0"
  }
}
