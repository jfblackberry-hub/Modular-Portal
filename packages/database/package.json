{
  "name": "@payer-portal/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:seed:employer-groups": "node --import tsx prisma/seed-employer-groups.ts",
    "db:seed:eb-demo": "node --import tsx prisma/seed-eb-demo.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "node -e \"console.log('No tests configured for @payer-portal/database')\""
  },
  "dependencies": {
    "@prisma/client": "^6.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3"
  }
}
