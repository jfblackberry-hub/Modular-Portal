generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  ONBOARDING
  INACTIVE
}

enum TenantType {
  PAYER
  CLINIC
  PHYSICIAN_GROUP
  HOSPITAL
  PROVIDER
}

enum PreviewSessionMode {
  READ_ONLY
  FUNCTIONAL
}

enum ApiCatalogCategory {
  CLAIMS
  PHARMACY
  ELIGIBILITY
  CLINICAL
  AUTHORIZATION
}

enum OrganizationUnitType {
  ENTERPRISE
  REGION
  LOCATION
  DEPARTMENT
  TEAM
}

enum UserLifecycleStatus {
  INVITED
  ACTIVE
  DISABLED
}

model Tenant {
  id            String        @id @default(uuid()) @db.Uuid
  name          String
  slug          String        @unique
  isActive      Boolean       @default(true)
  status        TenantStatus  @default(ONBOARDING)
  type          TenantType    @default(PAYER)
  tenantTypeCode String       @default("PAYER")
  templateId    String?       @db.Uuid
  brandingConfig Json         @default("{}")
  tenantTypeDefinition TenantTypeDefinition @relation(fields: [tenantTypeCode], references: [code], onDelete: Restrict)
  template      TenantTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  branding      TenantBranding?
  employerGroups EmployerGroup[]
  users         User[]        @relation("UserPrimaryTenant")
  memberships   UserTenantMembership[]
  roleAssignments UserRole[]
  auditLogs     AuditLog[]
  documents     Document[]
  jobs          Job[]
  notifications Notification[]
  connectorConfigs ConnectorConfig[]
  integrationExecutions IntegrationExecution[]
  providerWorkflowExecutions ProviderWorkflowExecution[]
  providerResourceCalendarSlots ProviderResourceCalendarSlot[]
  experiences   TenantExperience[]
  capabilityConfigs TenantCapabilityConfig[]
  featureFlags FeatureFlag[]
  eventRecords  EventRecord[]
  organizationUnits OrganizationUnit[]
  organizationUnitAssignments UserOrganizationUnitAssignment[]
  previewSessions PreviewSession[]
  portalAuthHandoffs PortalAuthHandoff[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([tenantTypeCode])
  @@index([templateId])
}

model OrganizationUnit {
  id        String               @id @default(uuid()) @db.Uuid
  tenantId  String               @db.Uuid
  parentId  String?              @db.Uuid
  type      OrganizationUnitType
  name      String
  metadata  Json?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   OrganizationUnit?  @relation("OrganizationUnitHierarchy", fields: [parentId, tenantId], references: [id, tenantId], onDelete: Restrict)
  children OrganizationUnit[] @relation("OrganizationUnitHierarchy")
  memberships UserTenantMembership[]
  userAssignments UserOrganizationUnitAssignment[]
  providerWorkflowExecutions ProviderWorkflowExecution[] @relation("ProviderWorkflowExecutionOrganizationUnit")
  providerResourceCalendarSlots ProviderResourceCalendarSlot[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, parentId])
}

model TenantBranding {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @unique @db.Uuid
  displayName    String?
  primaryColor   String?
  secondaryColor String?
  logoUrl        String?
  faviconUrl     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id          String     @id @default(uuid()) @db.Uuid
  tenantId    String?    @db.Uuid
  employerGroupId String? @db.Uuid
  email       String     @unique
  firstName   String
  lastName    String
  isActive    Boolean    @default(true)
  status      UserLifecycleStatus @default(ACTIVE)
  lastLoginAt DateTime?
  tenant      Tenant?    @relation("UserPrimaryTenant", fields: [tenantId], references: [id], onDelete: SetNull)
  memberships UserTenantMembership[]
  employerGroup EmployerGroup? @relation(fields: [employerGroupId], references: [id], onDelete: SetNull)
  credential  UserCredential?
  roles       UserRole[]
  organizationUnitAssignments UserOrganizationUnitAssignment[]
  auditLogs   AuditLog[]
  documents   Document[]
  notifications Notification[]
  providerWorkflowExecutions ProviderWorkflowExecution[] @relation("ProviderWorkflowExecutionInitiator")
  createdPreviewSessions PreviewSession[] @relation("PreviewSessionAdminUser")
  targetPreviewSessions  PreviewSession[] @relation("PreviewSessionTargetUser")
  portalAuthHandoffs PortalAuthHandoff[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tenantId])
  @@index([employerGroupId])
}

model UserOrganizationUnitAssignment {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  tenantId           String   @db.Uuid
  organizationUnitId String   @db.Uuid
  isDefault          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organizationUnit OrganizationUnit @relation(fields: [organizationUnitId, tenantId], references: [id, tenantId], onDelete: Cascade)

  @@unique([userId, tenantId, organizationUnitId])
  @@index([tenantId, organizationUnitId])
  @@index([userId, tenantId, isDefault])
}

model PreviewSession {
  id            String             @id @default(uuid()) @db.Uuid
  adminUserId   String             @db.Uuid
  tenantId      String             @db.Uuid
  targetUserId  String             @db.Uuid
  subTenantId   String?
  portalType    String
  persona       String
  mode          PreviewSessionMode
  launchToken   String             @unique
  createdAt     DateTime           @default(now())
  expiresAt     DateTime
  endedAt       DateTime?
  lastAccessedAt DateTime?
  currentRoute  String?
  currentRouteUpdatedAt DateTime?
  routeHistory  Json               @default("[]")

  adminUser  User   @relation("PreviewSessionAdminUser", fields: [adminUserId], references: [id], onDelete: Cascade)
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  targetUser User   @relation("PreviewSessionTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId, endedAt, createdAt])
  @@index([tenantId, endedAt])
  @@index([targetUserId, endedAt])
  @@index([expiresAt])
  @@index([currentRouteUpdatedAt])
}

model PortalAuthHandoff {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid
  userId       String   @db.Uuid
  audience     String
  redirectPath String
  accessToken  String
  userSnapshot Json
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([audience, expiresAt])
  @@index([consumedAt, expiresAt])
}

model UserTenantMembership {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  tenantId      String   @db.Uuid
  organizationUnitId String? @db.Uuid
  status        UserLifecycleStatus @default(ACTIVE)
  isDefault     Boolean  @default(false)
  isTenantAdmin Boolean  @default(false)
  invitedAt     DateTime?
  activatedAt   DateTime?
  disabledAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organizationUnit OrganizationUnit? @relation(fields: [organizationUnitId, tenantId], references: [id, tenantId], onDelete: Restrict)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId, isTenantAdmin])
  @@index([userId, isDefault])
  @@index([organizationUnitId])
  @@index([status])
}

model TenantTypeDefinition {
  code        String   @id
  enumValue   TenantType @unique
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenants Tenant[]
  roles   Role[]
  templates TenantTemplate[]
  experiences TenantExperience[]
  capabilityConfigs TenantCapabilityConfig[]
}

model TenantTemplate {
  id                      String   @id @default(uuid()) @db.Uuid
  code                    String   @unique
  name                    String
  tenantTypeCode          String
  description             String?
  defaultOrganizationUnitStructure Json @default("[]")
  defaultCapabilities     Json     @default("[]")
  defaultExperiences      Json     @default("[]")
  config                  Json     @default("{}")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenantTypeDefinition TenantTypeDefinition @relation(fields: [tenantTypeCode], references: [code], onDelete: Restrict)
  tenants              Tenant[]

  @@index([tenantTypeCode])
}

model CapabilityRegistryEntry {
  id           String   @id
  name         String
  category     String
  description  String?
  configSchema Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantCapabilityConfigs TenantCapabilityConfig[]
}

model TenantExperience {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  tenantTypeCode String
  key            String
  name           String
  description    String?
  scope          String   @default("tenant")
  layout         Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant                Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantTypeDefinition  TenantTypeDefinition @relation(fields: [tenantTypeCode], references: [code], onDelete: Restrict)
  capabilityConfigs     TenantCapabilityConfig[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([tenantTypeCode])
}

model TenantCapabilityConfig {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  tenantTypeCode String
  experienceId   String   @db.Uuid
  capabilityId   String
  enabled        Boolean  @default(true)
  scope          String   @default("tenant")
  displayOrder   Int      @default(0)
  config         Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant               Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantTypeDefinition TenantTypeDefinition    @relation(fields: [tenantTypeCode], references: [code], onDelete: Restrict)
  experience           TenantExperience        @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  capability           CapabilityRegistryEntry @relation(fields: [capabilityId], references: [id], onDelete: Restrict)

  @@unique([tenantId, experienceId, capabilityId])
  @@index([tenantId])
  @@index([tenantTypeCode])
  @@index([capabilityId])
}

model UserCredential {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  passwordHash      String
  mustResetPassword Boolean  @default(false)
  passwordSetAt     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmployerGroup {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  employerKey    String
  name           String
  logoUrl        String?
  isActive       Boolean  @default(true)
  brandingConfig Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]

  @@unique([tenantId, employerKey])
  @@index([tenantId, isActive])
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid
  userId    String?  @db.Uuid
  channel   String
  template  String
  subject   String?
  body      String
  status    String
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ConnectorConfig {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  adapterKey        String
  name              String
  status            String
  config            Json
  lastSyncAt        DateTime?
  lastHealthCheckAt DateTime?
  createdAt         DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  executions IntegrationExecution[]

  @@index([tenantId])
  @@index([adapterKey])
  @@index([status])
}

model IntegrationExecution {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  connectorConfigId String   @db.Uuid
  adapterKey        String
  triggerMode       String
  status            String
  startedAt         DateTime @default(now())
  finishedAt        DateTime?
  attempts          Int      @default(1)
  recordsProcessed  Int?
  eventsPublished   Int?
  message           String?
  metadata          Json?
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connectorConfig   ConnectorConfig @relation(fields: [connectorConfigId], references: [id], onDelete: Cascade)

  @@index([tenantId, startedAt])
  @@index([connectorConfigId, startedAt])
  @@index([status])
}

model Document {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  uploadedByUserId String   @db.Uuid
  filename         String
  mimeType         String
  sizeBytes        Int
  storageKey       String
  tags             Json?
  status           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedByUser User   @relation(fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Job {
  id          String   @id @default(uuid()) @db.Uuid
  type        String
  tenantId    String?  @db.Uuid
  payload     Json
  status      String
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  runAt       DateTime @default(now())
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status, runAt])
  @@index([tenantId])
  @@index([type])
  @@index([createdAt])
}

model ProviderWorkflowExecution {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @db.Uuid
  organizationUnitId String?  @db.Uuid
  initiatedByUserId  String?  @db.Uuid
  capabilityId       String
  widgetId           String?
  workflowType       String
  actionType         String
  targetType         String
  targetId           String
  targetLabel        String?
  personaCode        String?
  status             String
  jobId              String?  @db.Uuid
  inputPayload       Json
  resultPayload      Json?
  auditMetadata      Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  completedAt        DateTime?

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organizationUnit  OrganizationUnit? @relation("ProviderWorkflowExecutionOrganizationUnit", fields: [organizationUnitId, tenantId], references: [id, tenantId], onDelete: Restrict)
  initiatedByUser   User?             @relation("ProviderWorkflowExecutionInitiator", fields: [initiatedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([tenantId, organizationUnitId, createdAt])
  @@index([initiatedByUserId, createdAt])
  @@index([jobId])
}

model ProviderResourceCalendarSlot {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @db.Uuid
  organizationUnitId String?  @db.Uuid
  resourceId         String
  resourceName       String
  slotDate           DateTime @db.Date
  slotLabel          String
  status             String
  appointmentTitle   String?
  detail             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organizationUnit OrganizationUnit? @relation(fields: [organizationUnitId, tenantId], references: [id, tenantId], onDelete: Restrict)

  @@unique([tenantId, resourceId, slotDate, slotLabel])
  @@index([tenantId, resourceId, slotDate])
  @@index([tenantId, organizationUnitId, slotDate])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid
  actorUserId String?  @db.Uuid
  action      String
  entityType  String
  entityId    String?
  beforeState Json?
  afterState  Json?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actorUser User?  @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, action, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ApiCatalogEntry {
  id                 String             @id @default(uuid()) @db.Uuid
  slug               String             @unique
  name               String
  category           ApiCatalogCategory
  vendor             String             @default("Payer Platform")
  description        String
  endpoint           String
  version            String
  inputModels        Json               @default("[]")
  outputModels       Json               @default("[]")
  tenantAvailability Json               @default("[]")
  sortOrder          Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([category, sortOrder, name])
  @@map("api_catalog_entries")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  tenantTypeCode String?
  name        String
  description String?
  appliesToAllTenantTypes Boolean @default(false)
  isPlatformRole Boolean @default(false)
  users       UserRole[]
  permissions RolePermission[]
  tenantTypeDefinition TenantTypeDefinition? @relation(fields: [tenantTypeCode], references: [code], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([tenantTypeCode])
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  name        String
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model FeatureFlag {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @db.Uuid
  key         String
  name        String
  description String?
  enabled     Boolean  @default(false)
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@unique([key, tenantId])
}

model EventRecord {
  id            String          @id @default(uuid()) @db.Uuid
  type          String
  tenantId      String?         @db.Uuid
  correlationId String
  payload       Json
  metadata      Json?
  occurredAt    DateTime
  createdAt     DateTime        @default(now())
  tenant        Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveries    EventDelivery[]

  @@index([type, occurredAt])
  @@index([tenantId, occurredAt])
  @@index([correlationId])
}

model EventDelivery {
  id             String      @id @default(uuid()) @db.Uuid
  eventId        String      @db.Uuid
  subscriberId   String
  status         String
  attempts       Int         @default(0)
  maxAttempts    Int         @default(3)
  nextAttemptAt  DateTime?
  lastError      String?
  deadLetteredAt DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  event          EventRecord @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, subscriberId])
  @@index([status, nextAttemptAt])
  @@index([subscriberId, createdAt])
}

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  roleId     String   @db.Uuid
  tenantId   String?  @db.Uuid
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, tenantId])
  @@index([tenantId])
  @@index([roleId, tenantId])
}

model RolePermission {
  roleId       String   @db.Uuid
  permissionId String   @db.Uuid
  assignedAt   DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}
