{
  "name": "@payer-portal/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "backups:configure": "node dist/backups/runScheduledBackups.js",
    "backups:schedule": "tsx src/backups/runScheduledBackups.ts",
    "prebuild": "pnpm --filter @payer-portal/config build && pnpm --filter @payer-portal/api-contracts build",
    "build": "tsc -p tsconfig.json",
    "prelint": "pnpm --filter @payer-portal/config build && pnpm --filter @payer-portal/api-contracts build",
    "lint": "tsc --noEmit",
    "pretypecheck": "pnpm --filter @payer-portal/config build && pnpm --filter @payer-portal/api-contracts build",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-concurrency=1 tests/**/*.test.ts",
    "worker:jobs": "tsx src/jobs/runWorker.ts",
    "worker:start": "node ../../scripts/runtime/ensure-prisma-migrations.mjs job-worker && node dist/jobs/runWorker.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-prometheus": "^0.204.0",
    "@opentelemetry/sdk-metrics": "^2.1.0",
    "@payer-portal/api-contracts": "workspace:*",
    "@payer-portal/config": "workspace:*",
    "@payer-portal/database": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3"
  }
}
