{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "../..",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "types": ["node"]
  },
  "include": [
    "src/**/*",
    "test/**/*"
  ],
  "exclude": ["dist", "node_modules"]
}
