{
  "name": "@payer-portal/api-contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openapi": {
      "types": "./dist/openapi.d.ts",
      "default": "./dist/openapi.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx scripts/validate-openapi.ts"
  },
  "dependencies": {
    "@payer-portal/canonical-model": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.3"
  }
}
