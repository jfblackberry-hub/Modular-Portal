NODE_ENV="development"
HOST="0.0.0.0"
PORTAL_WEB_PORT="3000"
API_PORT="3002"
API_GATEWAY_PORT="3010"
ADMIN_CONSOLE_PORT="3003"
POSTGRES_PORT="5432"
# For single-service deployments, PUBLIC_ORIGIN can be used as an alias for the
# service-specific *_PUBLIC_ORIGIN variable that the app loader expects.
PORTAL_PUBLIC_ORIGIN="http://localhost:3000"
API_PUBLIC_ORIGIN="http://localhost:3002"
API_INTERNAL_ORIGIN="http://localhost:3002"
ADMIN_CONSOLE_PUBLIC_ORIGIN="http://localhost:3003"
API_GATEWAY_PUBLIC_ORIGIN="http://localhost:3010"
JOB_WORKER_POLL_INTERVAL_MS="1000"
TRUST_PROXY="false"
SECURE_COOKIES="false"
PORTAL_SESSION_COOKIE_DOMAIN=""
PORTAL_SESSION_COOKIE_SAME_SITE="lax"
ALLOW_INSECURE_PUBLIC_ORIGINS="true"
LOG_LEVEL="info"
OTEL_SERVICE_NAME=""
OTEL_PROMETHEUS_HOST="0.0.0.0"
OTEL_PROMETHEUS_PORT="9464"
OTEL_PROMETHEUS_PATH="/metrics"
STORAGE_PROVIDER="local"
LOCAL_STORAGE_DIR="storage"
LOCAL_PUBLIC_ASSET_DIR="apps/portal-web/public/tenant-assets"
LOCAL_PUBLIC_ASSET_BASE_PATH="/tenant-assets"
BACKUP_STORAGE_DIR="backups"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
DATABASE_URL="postgresql://dev:dev@127.0.0.1:5432/payer_portal?schema=public"
PORTAL_CATALOG_DATABASE_URL="mysql://portal_user:portal_pass@127.0.0.1:3306/portal_catalog"
# SESSION_SECRET can be used as a shared alias when a deployment only needs one
# runtime secret; service-specific secrets still take precedence when provided.
SESSION_SECRET="replace-with-strong-random-secret"
PORTAL_SESSION_SECRET="replace-with-strong-random-secret"
ADMIN_CONSOLE_SESSION_SECRET="replace-with-strong-random-secret"
API_AUTH_TOKEN_SECRET="replace-with-strong-random-secret"
API_GATEWAY_JWT_SECRET="replace-with-strong-random-secret"
# API Gateway rate limit (bounded in-memory per instance; see packages/api-gateway/RATE_LIMITING.md)
API_GATEWAY_RATE_LIMIT_MAX="100"
API_GATEWAY_RATE_LIMIT_WINDOW_MS="60000"
API_GATEWAY_RATE_LIMIT_MAX_TRACKED_KEYS="50000"
BACKUP_ENCRYPTION_KEY="replace-with-strong-random-secret"
